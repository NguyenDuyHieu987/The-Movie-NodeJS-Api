{
  "name": "the-movie-nodejs-api",
  "private": true,
  "main": "build/index.js",
  "scripts": {
    "start": "set NODE_ENV=development && cls && nodemon src/index.ts",
    "start:prod": "cross-env NODE_ENV=production && rimraf ./build && tsc && node build/index.js",
    "start:pm2": "cross-env NODE_ENV=production && rimraf ./build && tsc && pm2 start ecosystem.config.cjs",
    "build": "cross-env NODE_ENV=production && rimraf ./build && node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc",
    "typecheck": "tsc --noEmit --watch --preserveWatchOutput",
    "typecheck:once": "tsc --noEmit",
    "test": "jest",
    "migrate:es": "tsx src/migrate/index.ts",
    "lint": "eslint --cache src/**/*.{ts,cts,js,cjs}",
    "format": "eslint --fix --cache src/**/*.{ts,cts,js,cjs}",
    "lint-staged": "lint-staged",
    "prepare": "husky install"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@sendinblue/client": "3.3.1",
    "argon2": "0.44.0",
    "body-parser": "2.2.2",
    "chalk": "^5.6.2",
    "compression": "1.8.1",
    "connect-mongo": "6.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "cross-env": "10.1.0",
    "crypto": "1.0.1",
    "crypto-js": "4.2.0",
    "dayjs": "^1.11.19",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "express-session": "1.19.0",
    "googleapis": "171.4.0",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "http-errors": "2.0.1",
    "iso-3166-1": "^2.1.1",
    "iso-639-1": "^3.1.5",
    "jsonwebtoken": "9.0.3",
    "mathjs": "^15.1.1",
    "module-alias": "2.3.4",
    "moment": "2.30.1",
    "mongoose": "9.3.0",
    "multer": "2.1.1",
    "node-fetch": "3.3.2",
    "qs": "6.15.0",
    "redis": "5.11.0",
    "serve-favicon": "^2.5.1",
    "sib-api-v3-sdk": "8.5.0",
    "socket.io": "^4.8.3",
    "stripe": "20.4.1",
    "tsconfig-paths": "4.2.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/body-parser": "1.19.6",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/crypto-js": "4.2.2",
    "@types/express": "5.0.6",
    "@types/express-session": "1.18.2",
    "@types/jsonwebtoken": "9.0.10",
    "@types/module-alias": "2.0.4",
    "@types/multer": "2.1.0",
    "@types/node": "25.4.0",
    "@types/node-fetch": "2.6.13",
    "@types/request": "2.48.13",
    "@types/serve-favicon": "^2.5.7",
    "@types/uuid": "11.0.0",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "8.42.0",
    "@typescript-eslint/parser": "8.42.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.2.1",
    "eslint-plugin-n": "16.6.2",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "6.6.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "16.3.3",
    "nodemon": "3.1.14",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.x"
  }
}
